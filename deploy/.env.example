# Copy this file to `.env` (same folder) and adjust if you like.
# docker compose automatically reads `deploy/.env`.

# ---- Source Postgres (Step 2) ----
SOURCE_PG_USER=retail
SOURCE_PG_PASSWORD=retail_pw
SOURCE_PG_DB=retail
SOURCE_PG_PORT=5433          # host port -> container's 5432 (5433 avoids clashing with a native Postgres)

# ---- Databricks (Steps 3-4: dbt) ----
# Reuses the `airbyte-sp` service principal (OAuth M2M) already granted on catalog `retail`.
DBX_HOST=dbc-xxxxxxxx-xxxx.cloud.databricks.com   # workspace host, NO https://
DBX_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx     # SQL warehouse -> Connection details
DBX_CATALOG=retail
DBX_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx # airbyte-sp Application ID
DBX_CLIENT_SECRET=dose_xxxxxxxxxxxxxxxxxxxxxxxx     # airbyte-sp OAuth secret
