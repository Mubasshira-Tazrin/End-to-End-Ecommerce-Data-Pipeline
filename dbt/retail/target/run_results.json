nique_id": "test.retail.relationships_stg_orders_customer_id__customer_id__ref_stg_customers_.430bf21500", "compiled": true, "compiled_code": "\n    \n    \n\nwith child as (\n    select customer_id as from_field\n    from `retail`.`silver`.`stg_orders`\n    where customer_id is not null\n),\n\nparent as (\n    select customer_id as to_field\n    from `retail`.`silver`.`stg_customers`\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-08T10:22:48.324446Z", "completed_at": "2026-07-08T10:22:48.334039Z"}, {"name": "execute", "started_at": "2026-07-08T10:22:48.337247Z", "completed_at": "2026-07-08T10:22:48.337262Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.050173044204711914, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.retail.unique_stg_orders_order_id.e3b841c71a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    order_id as unique_field,\n    count(*) as n_records\n\nfrom `retail`.`silver`.`stg_orders`\nwhere order_id is not null\ngroup by order_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-08T10:22:48.343714Z", "completed_at": "2026-07-08T10:22:48.367103Z"}, {"name": "execute", "started_at": "2026-07-08T10:22:48.368944Z", "completed_at": "2026-07-08T10:22:48.368963Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.03451871871948242, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.retail.fact_sales", "compiled": true, "compiled_code": "-- Gold: sales fact. GRAIN = one order line item.\n-- Joins order_items -> orders (for customer + date) -> payments (method/status),\n-- carries surrogate FKs to every dimension, and computes line_amount.\nwith order_items as (\n    select * from `retail`.`silver`.`stg_order_items`\n),\n\norders as (\n    select * from `retail`.`silver`.`stg_orders`\n),\n\n-- one payment per order in the source; aggregate defensively so a stray duplicate\n-- can never fan out the fact grain.\npayments as (\n    select\n        order_id,\n        max(payment_method) as payment_method,\n        max(payment_status) as payment_status\n    from `retail`.`silver`.`stg_payments`\n    group by order_id\n)\n\nselect\n    md5(cast(concat(coalesce(cast(oi.order_item_id as string), '_dbt_utils_surrogate_key_null_')) as string)) as sales_key,\n    oi.order_id,\n    oi.order_item_id,\n    md5(cast(concat(coalesce(cast(o.customer_id as string), '_dbt_utils_surrogate_key_null_')) as string))   as customer_key,\n    md5(cast(concat(coalesce(cast(oi.product_id as string), '_dbt_utils_surrogate_key_null_')) as string))   as product_key,\n    cast(date_format(o.order_date, 'yyyyMMdd') as int)          as date_key,\n    oi.quantity,\n    oi.unit_price,\n    oi.quantity * oi.unit_price                                 as line_amount,\n    p.payment_method,\n    p.payment_status\nfrom order_items oi\njoin orders o\n    on oi.order_id = o.order_id\nleft join payments p\n    on oi.order_id = p.order_id", "relation_name": "`retail`.`gold`.`fact_sales`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-08T10:22:48.352460Z", "completed_at": "2026-07-08T10:22:48.368180Z"}, {"name": "execute", "started_at": "2026-07-08T10:22:48.377359Z", "completed_at": "2026-07-08T10:22:48.377371Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.04111194610595703, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.retail.accepted_values_stg_payments_payment_method__CARD__PAYPAL__BANK_TRANSFER__CASH.8f937b7ba5", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        payment_method as value_field,\n        count(*)